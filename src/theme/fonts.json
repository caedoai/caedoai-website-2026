{
  "families": {
    "display": "'Bebas Neue', sans-serif",
    "accent": "'Syne', sans-serif",
    "body": "'DM Sans', sans-serif"
  },
  "weights": {
    "light": 300,
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700,
    "black": 800
  },
  "sizes": {
    "xs": "11px",
    "sm": "13px",
    "base": "14px",
    "lg": "16px",
    "xl": "17px",
    "2xl": "24px",
    "3xl": "32px",
    "4xl": "56px"
  },
  "lineHeights": {
    "tight": 1.05,
    "normal": 1.2,
    "relaxed": 1.4
  },
  "letterSpacing": {
    "tight": "-0.02em",
    "normal": "0em",
    "wide": "0.04em",
    "wider": "0.08em",
    "widest": "0.16em"
  }
